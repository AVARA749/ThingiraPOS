generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Shop {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  address   String?
  phone     String?
  email     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  users          User[]
  suppliers      Supplier[]
  items          Item[]
  purchases      Purchase[]
  customers      Customer[]
  sales          Sale[]
  saleItems      SaleItem[]
  stockMovements StockMovement[]
  creditLedgers  CreditLedger[]
  creditPayments CreditPayment[]
  generalLedgers GeneralLedger[]
  shiftRegisters ShiftRegister[]

  @@map("shops")
}

model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  email        String?  @unique
  passwordHash String   @map("password_hash")
  fullName     String   @map("full_name")
  shopName     String?  @map("shop_name")
  phone        String?
  role         String   @default("staff")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")
  shopId       String?  @map("shop_id") @db.Uuid
  shop         Shop?    @relation(fields: [shopId], references: [id], onDelete: Cascade)
  clerkUserId  String?  @unique @map("clerk_user_id")

  shiftRegisters ShiftRegister[]

  @@map("users")
}

model Supplier {
  id        Int      @id @default(autoincrement())
  name      String
  address   String?
  phone     String?
  email     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  shopId    String?  @map("shop_id") @db.Uuid
  shop      Shop?    @relation(fields: [shopId], references: [id], onDelete: Cascade)

  items Item[]

  @@map("suppliers")
}

model Item {
  id            Int      @id @default(autoincrement())
  name          String
  buyingPrice   Decimal  @default(0) @map("buying_price") @db.Decimal(10, 2)
  sellingPrice  Decimal  @default(0) @map("selling_price") @db.Decimal(10, 2)
  quantity      Int      @default(0)
  minStockLevel Int      @default(5) @map("min_stock_level")
  supplierId    Int?     @map("supplier_id")
  category      String?  @default("General")
  barcode       String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")
  shopId        String?  @map("shop_id") @db.Uuid
  shop          Shop?    @relation(fields: [shopId], references: [id], onDelete: Cascade)

  supplier Supplier? @relation(fields: [supplierId], references: [id])

  @@map("items")
}

model Purchase {
  id            Int      @id @default(autoincrement())
  supplierId    Int      @map("supplier_id")
  itemId        Int      @map("item_id")
  quantity      Int
  buyingPrice   Decimal  @map("buying_price") @db.Decimal(10, 2)
  totalCost     Decimal  @map("total_cost") @db.Decimal(10, 2)
  datePurchased DateTime @default(now()) @map("date_purchased") @db.Date
  notes         String?
  createdAt     DateTime @default(now()) @map("created_at")
  shopId        String?  @map("shop_id") @db.Uuid
  shop          Shop?    @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@map("purchases")
}

model Customer {
  id          Int      @id @default(autoincrement())
  name        String
  phone       String?
  email       String?
  address     String?
  totalCredit Decimal? @default(0) @map("total_credit") @db.Decimal(10, 2)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")
  shopId      String?  @map("shop_id") @db.Uuid
  shop        Shop?    @relation(fields: [shopId], references: [id], onDelete: Cascade)

  sales         Sale[]
  creditLedgers CreditLedger[]

  @@map("customers")
}

model Sale {
  id            Int      @id @default(autoincrement())
  receiptNumber String?  @map("receipt_number")
  customerId    Int?     @map("customer_id")
  customerName  String?  @map("customer_name")
  customerPhone String?  @map("customer_phone")
  totalAmount   Decimal  @default(0) @map("total_amount") @db.Decimal(10, 2)
  paymentType   String   @default("cash") @map("payment_type")
  status        String?  @default("completed")
  notes         String?
  createdAt     DateTime @default(now()) @map("created_at")
  shopId        String?  @map("shop_id") @db.Uuid
  shop          Shop?    @relation(fields: [shopId], references: [id], onDelete: Cascade)

  customer  Customer?  @relation(fields: [customerId], references: [id])
  saleItems SaleItem[]

  @@unique([shopId, receiptNumber])
  @@map("sales")
}

model SaleItem {
  id          Int      @id @default(autoincrement())
  saleId      Int      @map("sale_id")
  itemId      Int      @map("item_id")
  itemName    String   @map("item_name")
  quantity    Int
  unitPrice   Decimal  @map("unit_price") @db.Decimal(10, 2)
  buyingPrice Decimal  @default(0) @map("buying_price") @db.Decimal(10, 2)
  subtotal    Decimal  @map("subtotal") @db.Decimal(10, 2)
  createdAt   DateTime @default(now()) @map("created_at")
  shopId      String?  @map("shop_id") @db.Uuid
  shop        Shop?    @relation(fields: [shopId], references: [id], onDelete: Cascade)

  sale Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@map("sale_items")
}

model StockMovement {
  id            Int      @id @default(autoincrement())
  itemId        Int      @map("item_id")
  itemName      String   @map("item_name")
  movementType  String   @map("movement_type")
  quantity      Int
  balanceAfter  Int      @default(0) @map("balance_after")
  referenceType String?  @map("reference_type")
  referenceId   Int?     @map("reference_id")
  supplierName  String?  @map("supplier_name")
  notes         String?
  createdAt     DateTime @default(now()) @map("created_at")
  shopId        String?  @map("shop_id") @db.Uuid
  shop          Shop?    @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@map("stock_movements")
}

model CreditLedger {
  id           Int       @id @default(autoincrement())
  customerId   Int       @map("customer_id")
  customerName String    @map("customer_name")
  saleId       Int       @map("sale_id")
  amount       Decimal   @map("amount") @db.Decimal(10, 2)
  paidAmount   Decimal?  @default(0) @map("paid_amount") @db.Decimal(10, 2)
  balance      Decimal   @map("balance") @db.Decimal(10, 2)
  status       String    @default("unpaid")
  dueDate      DateTime? @map("due_date") @db.Date
  notes        String?
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at")
  shopId       String?   @map("shop_id") @db.Uuid
  shop         Shop?     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  customer Customer @relation(fields: [customerId], references: [id])

  @@map("credit_ledger")
}

model CreditPayment {
  id            Int      @id @default(autoincrement())
  creditId      Int      @map("credit_id")
  customerId    Int      @map("customer_id")
  amount        Decimal  @db.Decimal(10, 2)
  paymentMethod String   @default("cash") @map("payment_method")
  notes         String?
  createdAt     DateTime @default(now()) @map("created_at")
  shopId        String?  @map("shop_id") @db.Uuid
  shop          Shop?    @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@map("credit_payments")
}

model GeneralLedger {
  id          Int      @id @default(autoincrement())
  date        DateTime @db.Date
  description String
  debit       Decimal? @db.Decimal(10, 2)
  credit      Decimal? @db.Decimal(10, 2)
  balance     Decimal  @db.Decimal(10, 2)
  reference   String?
  createdAt   DateTime @default(now()) @map("created_at")
  shopId      String?  @map("shop_id") @db.Uuid
  shop        Shop?    @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@map("general_ledger")
}

model ShiftRegister {
  id        Int       @id @default(autoincrement())
  userId    Int       @map("user_id")
  user      User      @relation(fields: [userId], references: [id])
  startTime DateTime  @map("start_time")
  endTime   DateTime? @map("end_time")
  startCash Decimal   @map("start_cash") @db.Decimal(10, 2)
  endCash   Decimal?  @map("end_cash") @db.Decimal(10, 2)
  status    String    @default("open")
  createdAt DateTime  @default(now()) @map("created_at")
  shopId    String?   @map("shop_id") @db.Uuid
  shop      Shop?     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@map("shift_registers")
}
