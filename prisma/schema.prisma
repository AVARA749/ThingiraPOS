generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Shop {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  address   String?
  phone     String?
  email     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  users             User[]
  suppliers         Supplier[]
  items             Item[]
  purchases         Purchase[]
  customers         Customer[]
  sales             Sale[]
  saleItems         SaleItem[]
  stockMovements    StockMovement[]
  creditLedgers    CreditLedger[]
  creditPayments   CreditPayment[]
  generalLedgers    GeneralLedger[]
  shiftRegisters   ShiftRegister[]
  pumps             Pump[]

  @@map("shops")
}

enum UserRole {
  admin
  staff
}

model User {
  id          String   @id @default(uuid()) @db.Uuid
  username    String   @unique
  email       String?  @unique
  fullName    String   @map("full_name")
  shopName    String?  @map("shop_name")
  phone       String?
  role        UserRole @default(staff)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")
  shopId      String?  @map("shop_id") @db.Uuid
  shop        Shop?    @relation(fields: [shopId], references: [id], onDelete: Cascade)
  clerkUserId String?  @unique @map("clerk_user_id")

  shiftRegisters ShiftRegister[]

  @@map("users")
}

model Supplier {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  address   String?
  phone     String?
  email     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  shopId    String?  @map("shop_id") @db.Uuid
  shop      Shop?    @relation(fields: [shopId], references: [id], onDelete: Cascade)

  items Item[]

  @@map("suppliers")
}

model Item {
  id            String   @id @default(uuid()) @db.Uuid
  name          String
  buyingPrice   Decimal  @default(0) @map("buying_price") @db.Decimal(10, 2)
  sellingPrice  Decimal  @default(0) @map("selling_price") @db.Decimal(10, 2)
  quantity      Int      @default(0)
  minStockLevel Int      @default(5) @map("min_stock_level")
  supplierId    String?  @map("supplier_id") @db.Uuid
  category      String?  @default("General")
  barcode       String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")
  shopId        String?  @map("shop_id") @db.Uuid
  shop          Shop?    @relation(fields: [shopId], references: [id], onDelete: Cascade)

  supplier Supplier? @relation(fields: [supplierId], references: [id])

  @@map("items")
}

model Purchase {
  id            String   @id @default(uuid()) @db.Uuid
  supplierId    String   @map("supplier_id") @db.Uuid
  itemId        String   @map("item_id") @db.Uuid
  quantity      Int
  buyingPrice   Decimal  @map("buying_price") @db.Decimal(10, 2)
  totalCost     Decimal  @map("total_cost") @db.Decimal(10, 2)
  datePurchased DateTime @default(now()) @map("date_purchased") @db.Date
  notes         String?
  createdAt     DateTime @default(now()) @map("created_at")
  shopId        String?  @map("shop_id") @db.Uuid
  shop          Shop?    @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@map("purchases")
}

model Customer {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  phone       String?
  email       String?
  address     String?
  totalCredit Decimal? @default(0) @map("total_credit") @db.Decimal(10, 2)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")
  shopId      String?  @map("shop_id") @db.Uuid
  shop        Shop?    @relation(fields: [shopId], references: [id], onDelete: Cascade)

  sales          Sale[]
  creditLedgers CreditLedger[]
  creditPayments CreditPayment[]

  @@map("customers")
}

model Sale {
  id            String   @id @default(uuid()) @db.Uuid
  receiptNumber String?  @map("receipt_number")
  customerId    String?  @map("customer_id") @db.Uuid
  customerName  String?  @map("customer_name")
  customerPhone String?  @map("customer_phone")
  totalAmount   Decimal  @default(0) @map("total_amount") @db.Decimal(10, 2)
  paymentType   String   @default("cash") @map("payment_type")
  status        String?  @default("completed")
  notes         String?
  createdAt     DateTime @default(now()) @map("created_at")
  shopId        String?  @map("shop_id") @db.Uuid
  shop          Shop?    @relation(fields: [shopId], references: [id], onDelete: Cascade)

  customer  Customer?  @relation(fields: [customerId], references: [id])
  saleItems SaleItem[]
  creditLedgers CreditLedger[]

  @@unique([shopId, receiptNumber])
  @@map("sales")
}

model SaleItem {
  id          String   @id @default(uuid()) @db.Uuid
  saleId      String   @map("sale_id") @db.Uuid
  itemId      String   @map("item_id") @db.Uuid
  itemName    String   @map("item_name")
  quantity    Int
  unitPrice   Decimal  @map("unit_price") @db.Decimal(10, 2)
  buyingPrice Decimal  @default(0) @map("buying_price") @db.Decimal(10, 2)
  subtotal    Decimal  @map("subtotal") @db.Decimal(10, 2)
  createdAt   DateTime @default(now()) @map("created_at")
  shopId      String?  @map("shop_id") @db.Uuid
  shop        Shop?    @relation(fields: [shopId], references: [id], onDelete: Cascade)

  sale Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@map("sale_items")
}

model StockMovement {
  id            String   @id @default(uuid()) @db.Uuid
  itemId        String   @map("item_id") @db.Uuid
  itemName      String   @map("item_name")
  movementType  String   @map("movement_type")
  quantity      Int
  balanceAfter  Int      @default(0) @map("balance_after")
  referenceType String?  @map("reference_type")
  referenceId   String?  @map("reference_id") @db.Uuid
  supplierName  String?  @map("supplier_name")
  notes         String?
  createdAt     DateTime @default(now()) @map("created_at")
  shopId        String?  @map("shop_id") @db.Uuid
  shop          Shop?    @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@map("stock_movements")
}

model CreditLedger {
  id           String    @id @default(uuid()) @db.Uuid
  customerId   String    @map("customer_id") @db.Uuid
  customerName String    @map("customer_name")
  saleId       String    @map("sale_id") @db.Uuid
  amount       Decimal   @map("amount") @db.Decimal(10, 2)
  paidAmount   Decimal?  @default(0) @map("paid_amount") @db.Decimal(10, 2)
  balance      Decimal   @map("balance") @db.Decimal(10, 2)
  status       String    @default("unpaid")
  dueDate      DateTime? @map("due_date") @db.Date
  notes        String?
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at")
  shopId       String?   @map("shop_id") @db.Uuid
  shop         Shop?     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  customer Customer @relation(fields: [customerId], references: [id])
  sale     Sale     @relation(fields: [saleId], references: [id])
  creditPayments CreditPayment[]

  @@map("credit_ledger")
}

model CreditPayment {
  id            String   @id @default(uuid()) @db.Uuid
  creditId      String   @map("credit_id") @db.Uuid
  customerId    String   @map("customer_id") @db.Uuid
  amount        Decimal  @db.Decimal(10, 2)
  paymentMethod String   @default("cash") @map("payment_method")
  notes         String?
  createdAt     DateTime @default(now()) @map("created_at")
  shopId        String?  @map("shop_id") @db.Uuid
  shop          Shop?    @relation(fields: [shopId], references: [id], onDelete: Cascade)

  customer     Customer     @relation(fields: [customerId], references: [id])
  creditLedger CreditLedger @relation(fields: [creditId], references: [id])

  @@map("credit_payments")
}

model GeneralLedger {
  id          String   @id @default(uuid()) @db.Uuid
  date        DateTime @db.Date
  description String
  debit       Decimal? @db.Decimal(10, 2)
  credit      Decimal? @db.Decimal(10, 2)
  balance     Decimal  @db.Decimal(10, 2)
  reference   String?
  createdAt   DateTime @default(now()) @map("created_at")
  shopId      String?  @map("shop_id") @db.Uuid
  shop        Shop?    @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@map("general_ledger")
}

// ============== FUEL STATION MODELS ==============

model ShiftRegister {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  user      User      @relation(fields: [userId], references: [id])
  startTime DateTime? @map("start_time")
  endTime   DateTime? @map("end_time")
  startCash Decimal?  @map("start_cash") @db.Decimal(10, 2)
  endCash   Decimal?  @map("end_cash") @db.Decimal(10, 2)
  status    String    @default("assigned")
  createdAt DateTime  @default(now()) @map("created_at")
  shopId    String?   @map("shop_id") @db.Uuid
  shop      Shop?     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  // Enhanced fuel station fields
  notes            String?   @map("notes")
  expectedCash     Decimal?  @map("expected_cash") @db.Decimal(10, 2)
  actualCash       Decimal?  @map("actual_cash") @db.Decimal(10, 2)
  variance         Decimal?  @map("variance") @db.Decimal(10, 2)
  totalCashSales   Decimal?  @map("total_cash_sales") @db.Decimal(10, 2)
  totalCardSales   Decimal?  @map("total_card_sales") @db.Decimal(10, 2)
  totalMpesaSales  Decimal?  @map("total_mpesa_sales") @db.Decimal(10, 2)

  nozzleShiftReadings NozzleShiftReading[]

  @@map("shift_registers")
}

// Fuel type enum
enum FuelType {
  petrol
  diesel
  kerosene
}

// Pump model - represents a fuel pump
model Pump {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  pumpNumber Int     @unique
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  shopId    String?  @map("shop_id") @db.Uuid
  shop      Shop?    @relation(fields: [shopId], references: [id], onDelete: Cascade)

  nozzles Nozzle[]

  @@map("pumps")
}

// Nozzle model - each pump has multiple nozzles for different fuel types
model Nozzle {
  id        String    @id @default(uuid()) @db.Uuid
  pumpId    String    @map("pump_id") @db.Uuid
  pump      Pump      @relation(fields: [pumpId], references: [id], onDelete: Cascade)
  nozzleNumber Int
  fuelType  FuelType  @map("fuel_type")
  unitPrice Decimal   @default(0) @map("unit_price") @db.Decimal(10, 2)
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at")

  nozzleShiftReadings NozzleShiftReading[]

  @@unique([pumpId, nozzleNumber])
  @@map("nozzles")
}

// Nozzle shift readings - tracks meter readings at start/end of each shift
model NozzleShiftReading {
  id              String    @id @default(uuid()) @db.Uuid
  shiftId         String    @map("shift_id") @db.Uuid
  shift           ShiftRegister @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  nozzleId        String    @map("nozzle_id") @db.Uuid
  nozzle          Nozzle    @relation(fields: [nozzleId], references: [id], onDelete: Cascade)
  openingReading  Decimal   @map("opening_reading") @db.Decimal(12, 2)
  closingReading  Decimal?  @map("closing_reading") @db.Decimal(12, 2)
  openingTime    DateTime  @map("opening_time")
  closingTime    DateTime? @map("closing_time")
  volumeSold     Decimal?   @map("volume_sold") @db.Decimal(12, 2)
  amountSold     Decimal?   @map("amount_sold") @db.Decimal(12, 2)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at")

  @@unique([shiftId, nozzleId])
  @@map("nozzle_shift_readings")
}


