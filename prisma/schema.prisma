generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Shop {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  address   String?
  phone     String?
  email     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  users             User[]
  suppliers         Supplier[]
  items             Item[]
  purchases         Purchase[]
  customers         Customer[]
  sales             Sale[]
  saleItems         SaleItem[]
  stockMovements    StockMovement[]
  creditLedgers    CreditLedger[]
  creditPayments   CreditPayment[]
  generalLedgers    GeneralLedger[]
  shiftRegisters    ShiftRegister[]
  pumps             Pump[]
  shifts            Shift[]
  categories        Category[]
  tanks             Tank[]

  @@map("shops")
}

enum UserRole {
  admin
  cashier
  fuel_station_attendant
}

model User {
  id          String   @id @default(uuid()) @db.Uuid
  username    String   @unique
  email       String?  @unique
  fullName    String   @map("full_name")
  shopName    String?  @map("shop_name")
  phone       String?
  role        UserRole @default(cashier)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")
  shopId      String?  @map("shop_id") @db.Uuid
  shop        Shop?    @relation(fields: [shopId], references: [id], onDelete: Cascade)
  clerkUserId String?  @unique @map("clerk_user_id")

  shiftRegisters ShiftRegister[]
  purchases      Purchase[]
  stockMovements StockMovement[]
  creditLedgers  CreditLedger[]
  creditPayments CreditPayment[]
  generalLedgers GeneralLedger[]
  sales          Sale[]

  @@map("users")
}

model Supplier {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  address   String?
  phone     String?
  email     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  shopId    String?  @map("shop_id") @db.Uuid
  shop      Shop?    @relation(fields: [shopId], references: [id], onDelete: Cascade)

  items Item[]

  @@map("suppliers")
}

model Item {
  id            String   @id @default(uuid()) @db.Uuid
  name          String
  buyingPrice   Decimal  @default(0) @map("buying_price") @db.Decimal(10, 2)
  sellingPrice  Decimal  @default(0) @map("selling_price") @db.Decimal(10, 2)
  quantity      Decimal  @default(0) @db.Decimal(12, 3)
  minStockLevel Int      @default(5) @map("min_stock_level")
  supplierId    String?  @map("supplier_id") @db.Uuid
  categoryId    String?  @map("category_id") @db.Uuid
  category      Category? @relation(fields: [categoryId], references: [id])
  barcode       String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")
  shopId        String?  @map("shop_id") @db.Uuid
  shop          Shop?    @relation(fields: [shopId], references: [id], onDelete: Cascade)

  supplier       Supplier? @relation(fields: [supplierId], references: [id])
  stockMovements StockMovement[]

  @@map("items")
}

model Purchase {
  id            String   @id @default(uuid()) @db.Uuid
  supplierId    String   @map("supplier_id") @db.Uuid
  itemId        String   @map("item_id") @db.Uuid
  quantity      Decimal  @db.Decimal(12, 3)
  buyingPrice   Decimal  @map("buying_price") @db.Decimal(10, 2)
  totalCost     Decimal  @map("total_cost") @db.Decimal(10, 2)
  datePurchased DateTime @default(now()) @map("date_purchased") @db.Date
  notes         String?
  createdAt     DateTime @default(now()) @map("created_at")
  shopId        String?  @map("shop_id") @db.Uuid
  shop          Shop?    @relation(fields: [shopId], references: [id], onDelete: Cascade)
  userId        String?  @map("user_id") @db.Uuid
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("purchases")
}

model Customer {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  phone       String?
  email       String?
  address     String?
  totalCredit Decimal? @default(0) @map("total_credit") @db.Decimal(10, 2)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")
  shopId      String?  @map("shop_id") @db.Uuid
  shop        Shop?    @relation(fields: [shopId], references: [id], onDelete: Cascade)

  sales          Sale[]
  creditLedgers CreditLedger[]
  creditPayments CreditPayment[]

  @@map("customers")
}

model Sale {
  id            String   @id @default(uuid()) @db.Uuid
  receiptNumber String?  @map("receipt_number")
  customerId    String?  @map("customer_id") @db.Uuid
  customerName  String?  @map("customer_name")
  customerPhone String?  @map("customer_phone")
  totalAmount   Decimal  @default(0) @map("total_amount") @db.Decimal(10, 2)
  paymentType   String   @default("cash") @map("payment_type")
  status        String?  @default("completed")
  notes         String?
  createdAt     DateTime @default(now()) @map("created_at")
  shopId        String?  @map("shop_id") @db.Uuid
  shop          Shop?    @relation(fields: [shopId], references: [id], onDelete: Cascade)
  userId        String?  @map("user_id") @db.Uuid
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  customer  Customer?  @relation(fields: [customerId], references: [id])
  saleItems SaleItem[]
  creditLedgers CreditLedger[]

  shiftId       String?    @map("shift_id") @db.Uuid
  shift         ShiftRegister? @relation(fields: [shiftId], references: [id])

  @@unique([shopId, receiptNumber])
  @@map("sales")
}

model SaleItem {
  id          String   @id @default(uuid()) @db.Uuid
  saleId      String   @map("sale_id") @db.Uuid
  itemId      String   @map("item_id") @db.Uuid
  itemName    String   @map("item_name")
  quantity    Decimal  @db.Decimal(12, 3)
  unitPrice   Decimal  @map("unit_price") @db.Decimal(10, 2)
  buyingPrice Decimal  @default(0) @map("buying_price") @db.Decimal(10, 2)
  subtotal    Decimal  @map("subtotal") @db.Decimal(10, 2)
  createdAt   DateTime @default(now()) @map("created_at")
  shopId      String?  @map("shop_id") @db.Uuid
  shop        Shop?    @relation(fields: [shopId], references: [id], onDelete: Cascade)

  sale Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@map("sale_items")
}

model StockMovement {
  id            String   @id @default(uuid()) @db.Uuid
  movementType  String   @map("movement_type")
  quantity      Decimal  @db.Decimal(12, 3)
  balanceAfter  Decimal  @default(0) @map("balance_after") @db.Decimal(12, 3)
  referenceType String?  @map("reference_type")
  referenceId   String?  @map("reference_id") @db.Uuid
  supplierName  String?  @map("supplier_name")
  notes         String?
  createdAt     DateTime @default(now()) @map("created_at")
  shopId        String?  @map("shop_id") @db.Uuid
  shop          Shop?    @relation(fields: [shopId], references: [id], onDelete: Cascade)
  userId        String?  @map("user_id") @db.Uuid
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Allow linking to either Item OR Tank
  itemId        String?  @map("item_id") @db.Uuid
  itemName      String?  @map("item_name")
  item          Item?    @relation(fields: [itemId], references: [id])
  
  tankId        String?  @map("tank_id") @db.Uuid
  tankName      String?  @map("tank_name")
  tank          Tank?    @relation(fields: [tankId], references: [id])

  @@map("stock_movements")
}

model CreditLedger {
  id           String    @id @default(uuid()) @db.Uuid
  customerId   String    @map("customer_id") @db.Uuid
  customerName String    @map("customer_name")
  saleId       String    @map("sale_id") @db.Uuid
  amount       Decimal   @map("amount") @db.Decimal(10, 2)
  paidAmount   Decimal?  @default(0) @map("paid_amount") @db.Decimal(10, 2)
  balance      Decimal   @map("balance") @db.Decimal(10, 2)
  status       String    @default("unpaid")
  dueDate      DateTime? @map("due_date") @db.Date
  notes        String?
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at")
  shopId       String?   @map("shop_id") @db.Uuid
  shop         Shop?     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  userId       String?   @map("user_id") @db.Uuid
  user         User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  customer Customer @relation(fields: [customerId], references: [id])
  sale     Sale     @relation(fields: [saleId], references: [id])
  creditPayments CreditPayment[]

  @@map("credit_ledger")
}

model CreditPayment {
  id            String   @id @default(uuid()) @db.Uuid
  creditId      String   @map("credit_id") @db.Uuid
  customerId    String   @map("customer_id") @db.Uuid
  amount        Decimal  @db.Decimal(10, 2)
  paymentMethod String   @default("cash") @map("payment_method")
  notes         String?
  createdAt     DateTime @default(now()) @map("created_at")
  shopId        String?  @map("shop_id") @db.Uuid
  shop          Shop?    @relation(fields: [shopId], references: [id], onDelete: Cascade)
  userId        String?  @map("user_id") @db.Uuid
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  customer     Customer     @relation(fields: [customerId], references: [id])
  creditLedger CreditLedger @relation(fields: [creditId], references: [id])

  @@map("credit_payments")
}

model GeneralLedger {
  id          String   @id @default(uuid()) @db.Uuid
  date        DateTime @db.Date
  description String
  debit       Decimal? @db.Decimal(10, 2)
  credit      Decimal? @db.Decimal(10, 2)
  balance     Decimal  @db.Decimal(10, 2)
  reference   String?
  createdAt   DateTime @default(now()) @map("created_at")
  shopId      String?  @map("shop_id") @db.Uuid
  shop        Shop?    @relation(fields: [shopId], references: [id], onDelete: Cascade)
  userId      String?  @map("user_id") @db.Uuid
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("general_ledger")
}

// ============== FUEL STATION MODELS ==============

model Tank {
  id            String   @id @default(uuid()) @db.Uuid
  name          String   // e.g. "Underground Tank 1", "Overhead Tank"
  fuelType      FuelType @map("fuel_type") 
  capacity      Decimal  @map("capacity") @db.Decimal(12, 3) // Max Liters
  currentLevel  Decimal  @map("current_level") @db.Decimal(12, 3) // Current Liters
  
  // Fuel pricing is separate from Shop pricing
  currentPrice  Decimal  @map("current_price") @db.Decimal(10, 2) 
  
  minStockLevel Decimal  @map("min_stock_level") @db.Decimal(12, 3) // Alert level
  
  shopId        String   @map("shop_id") @db.Uuid
  shop          Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  // One Tank can feed multiple Pumps
  pumps         Pump[] 

  stockMovements StockMovement[] 

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("tanks")
}

model Shift {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   // e.g. Morning, Night
  startTime String?  @map("start_time") // HH:mm
  endTime   String?  @map("end_time")   // HH:mm
  shopId    String?  @map("shop_id") @db.Uuid
  shop      Shop?    @relation(fields: [shopId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  shiftRegisters ShiftRegister[]

  @@map("shifts")
}

model ShiftRegister {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  user      User      @relation(fields: [userId], references: [id])
  startTime DateTime? @map("start_time")
  endTime   DateTime? @map("end_time")
  shiftId   String?   @map("shift_id") @db.Uuid
  shift     Shift?    @relation(fields: [shiftId], references: [id])
  startCash Decimal?  @map("start_cash") @db.Decimal(10, 2)
  endCash   Decimal?  @map("end_cash") @db.Decimal(10, 2)
  status    String    @default("assigned")
  createdAt DateTime  @default(now()) @map("created_at")
  shopId    String?   @map("shop_id") @db.Uuid
  shop      Shop?     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  // Reconciliation fields
  openingNotes     String?   @map("opening_notes")
  closingNotes     String?   @map("closing_notes")
  
  expectedRevenue  Decimal?  @map("expected_revenue") @db.Decimal(10, 2) // From meters
  actualCash       Decimal?  @map("actual_cash") @db.Decimal(10, 2)     // Physical cash counted
  
  totalCashSales   Decimal?  @map("total_cash_sales") @db.Decimal(10, 2)   // Declared Cash Sales
  totalMpesaSales  Decimal?  @map("total_mpesa_sales") @db.Decimal(10, 2)  // Declared M-Pesa Sales
  totalCardSales   Decimal?  @map("total_card_sales") @db.Decimal(10, 2)   // Declared Card Sales
  totalCreditSales Decimal?  @map("total_credit_sales") @db.Decimal(10, 2) // Declared Credit Sales
  
  variance         Decimal?  @map("variance") @db.Decimal(10, 2) // actualCash - totalCashSales

  pumpShiftReadings PumpShiftReading[]
  sales             Sale[]

  @@map("shift_registers")
}

// Fuel type enum
enum FuelType {
  petrol
  diesel
  kerosene
}

// Pump model - represents a fuel pump as the source of truth
model Pump {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  pumpNumber Int     @unique
  
  fuelType  FuelType @default(petrol) @map("fuel_type")
  unitPrice Decimal  @default(0) @map("unit_price") @db.Decimal(10, 2)
  
  // CHANGE: Link to Tank instead of Item
  tankId    String?  @map("tank_id") @db.Uuid
  tank      Tank?    @relation(fields: [tankId], references: [id], onDelete: Restrict)

  // Totalizer Reading
  lastReading Decimal @default(0) @map("last_reading") @db.Decimal(12, 2)

  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  shopId    String?  @map("shop_id") @db.Uuid
  shop      Shop?    @relation(fields: [shopId], references: [id], onDelete: Cascade)

  pumpShiftReadings PumpShiftReading[]

  @@map("pumps")
}

// Replaces NozzleShiftReading
model PumpShiftReading {
  id              String    @id @default(uuid()) @db.Uuid
  shiftId         String    @map("shift_id") @db.Uuid
  shift           ShiftRegister @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  pumpId          String    @map("pump_id") @db.Uuid
  pump            Pump      @relation(fields: [pumpId], references: [id], onDelete: Cascade)
  
  openingReading  Decimal   @map("opening_reading") @db.Decimal(12, 2)
  closingReading  Decimal?  @map("closing_reading") @db.Decimal(12, 2)
  openingTime     DateTime  @map("opening_time")
  closingTime     DateTime? @map("closing_time")
  
  volumeSold      Decimal?   @map("volume_sold") @db.Decimal(12, 2)
  amountSold      Decimal?   @map("amount_sold") @db.Decimal(12, 2)
  
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at")

  @@unique([shiftId, pumpId])
  @@map("pump_shift_readings")
}
model Category {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  shopId    String   @map("shop_id") @db.Uuid
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  items     Item[]
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  // Ensure category names are unique within a shop
  @@unique([name, shopId]) 
  @@map("categories")
}
